# Environment variables - Template para outros devs
# Copie este arquivo para .env e preencha com seus valores

# === BANCO DE DADOS ===
DATABASE_URL=postgresql+asyncpg://usuario:senha@localhost:5432/nome_do_banco

# === REDIS ===
REDIS_URL=redis://localhost:6379/0

# === SEGURANÇA ===
SECRET_KEY=sua-chave-secreta-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === APLICAÇÃO ===
APP_NAME="Flow Process API"
APP_VERSION=0.1.0
DEBUG=True
ENVIRONMENT=development

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000